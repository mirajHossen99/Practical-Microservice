enum OrderStatus {
    PENDING
    CONFIRMED
    SHIPPED
    DELIVERED
    CANCELLED
}

model Order {
    id         String      @id @default(cuid())
    userId     String
    userName   String
    userEmail  String
    subTotal   Float       @default(0)
    tax        Float       @default(0)
    grandTotal Float       @default(0)
    status     OrderStatus @default(PENDING)
    
    orderItems OrderItem[]

    createdAt  DateTime    @default(now())
    updatedAt  DateTime    @updatedAt
}
